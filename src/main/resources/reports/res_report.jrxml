<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
    xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="res_report"
    pageWidth="595"
    pageHeight="842"
    columnWidth="555"
    leftMargin="20"
    rightMargin="20"
    topMargin="20"
    bottomMargin="20">

    <!-- ── Parameters ── -->
    <parameter name="REPORT_DATE" class="java.lang.String">
        <defaultValueExpression><![CDATA["—"]]></defaultValueExpression>
    </parameter>

    <!-- ── Fields ── -->
    <field name="batchId"    class="java.lang.String"/>
    <field name="chequeNo"   class="java.lang.String"/>
    <field name="chequeDate" class="java.time.LocalDateTime"/>
    <field name="micrCode"   class="java.lang.String"/>
    <field name="payeeName"  class="java.lang.String"/>
    <field name="amount"     class="java.math.BigDecimal"/>

    <!-- ── Variables ── -->

    <!-- Running subtotal per batch group -->
    <variable name="BATCH_SUBTOTAL" class="java.math.BigDecimal"
              resetType="Group" resetGroup="batchGroup"
              calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>

    <!-- Grand total across all batches -->
    <variable name="GRAND_TOTAL" class="java.math.BigDecimal"
              resetType="Report"
              calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>

    <!-- Row count per batch group -->
    <variable name="BATCH_COUNT" class="java.lang.Integer"
              resetType="Group" resetGroup="batchGroup"
              calculation="Count">
        <variableExpression><![CDATA[$F{chequeNo}]]></variableExpression>
        <initialValueExpression><![CDATA[0]]></initialValueExpression>
    </variable>

    <!-- Grand cheque count -->
    <variable name="GRAND_COUNT" class="java.lang.Integer"
              resetType="Report"
              calculation="Count">
        <variableExpression><![CDATA[$F{chequeNo}]]></variableExpression>
        <initialValueExpression><![CDATA[0]]></initialValueExpression>
    </variable>

    <!-- ── Group by batchId ── -->
    <group name="batchGroup" isStartNewPage="false" isReprintHeaderOnEachPage="true">
        <groupExpression><![CDATA[$F{batchId}]]></groupExpression>

        <!-- Group Header: batch label + column headings -->
        <groupHeader>
            <band height="48">

                <!-- Thin top rule -->
                <line>
                    <reportElement x="0" y="0" width="555" height="1" forecolor="#CCCCCC"/>
                </line>

                <!-- "Batch: Batch_001" label -->
                <textField>
                    <reportElement x="0" y="6" width="400" height="18"/>
                    <textElement>
                        <font size="10" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Batch:  " + $F{batchId}]]></textFieldExpression>
                </textField>

                <!-- Column headings row -->
                <rectangle>
                    <reportElement x="0" y="26" width="555" height="18" backcolor="#E8F0FE" forecolor="#E8F0FE"/>
                </rectangle>

                <staticText>
                    <reportElement x="2"   y="27" width="62" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Cheque No]]></text>
                </staticText>
                <staticText>
                    <reportElement x="66" y="27" width="68" height="16"/>
                    <textElement><font size="7" isBold="true"/></textElement>
                    <text><![CDATA[Date]]></text>
                </staticText>
                <staticText>
                    <reportElement x="138" y="27" width="86" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[MICR]]></text>
                </staticText>
                <staticText>
                    <reportElement x="228" y="27" width="188" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Payee Name]]></text>
                </staticText>
                <staticText>
                    <reportElement x="418" y="27" width="135" height="16"/>
                    <textElement textAlignment="Right"><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Amount (Rs.)]]></text>
                </staticText>
            </band>
        </groupHeader>

        <!-- Group Footer: subtotal row -->
        <groupFooter>
            <band height="26">
                <line>
                    <reportElement x="0" y="1" width="555" height="1" forecolor="#AAAAAA"/>
                </line>
                <staticText>
                    <reportElement x="226" y="4" width="187" height="16"/>
                    <textElement textAlignment="Right">
                        <font size="9" isBold="true"/>
                    </textElement>
                    <text><![CDATA[Batch Subtotal:]]></text>
                </staticText>
                <textField pattern="#,##0.00">
                    <reportElement x="418" y="4" width="135" height="16"/>
                    <textElement textAlignment="Right">
                        <font size="9" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$V{BATCH_SUBTOTAL}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- ── Title ── -->
    <title>
        <band height="60">

            <!-- Report heading -->
            <staticText>
                <reportElement x="0" y="0" width="400" height="24"/>
                <textElement>
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[RES REPORT — ACCEPTED CHEQUES]]></text>
            </staticText>

            <!-- Date on the right -->
            <textField>
                <reportElement x="400" y="0" width="155" height="16"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Date: " + $P{REPORT_DATE}]]></textFieldExpression>
            </textField>

            <!-- Horizontal rule under title -->
            <line>
                <reportElement x="0" y="30" width="555" height="1" forecolor="#1A56DB"/>
            </line>
        </band>
    </title>

    <!-- ── Detail rows ── -->
    <detail>
        <band height="18">

            <textField isBlankWhenNull="true">
                <reportElement x="2"   y="1" width="62" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{chequeNo}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="66" y="1" width="68" height="16"/>
                <textElement><font size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{chequeDate} != null ? $F{chequeDate}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yyyy")) : "-"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="138" y="1" width="86" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{micrCode}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="228" y="1" width="188" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{payeeName}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="418" y="1" width="135" height="16"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ── Summary: grand total ── -->
    <summary>
        <band height="36">
            <line>
                <reportElement x="0" y="2" width="555" height="1" forecolor="#1A56DB"/>
            </line>
            <staticText>
                <reportElement x="0" y="8" width="418" height="18"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[GRAND TOTAL:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="418" y="8" width="135" height="18"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{GRAND_TOTAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
