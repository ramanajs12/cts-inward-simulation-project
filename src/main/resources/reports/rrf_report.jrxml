<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
    xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="rrf_report"
    pageWidth="595"
    pageHeight="842"
    columnWidth="555"
    leftMargin="20"
    rightMargin="20"
    topMargin="20"
    bottomMargin="20">

    <!-- ── Parameters ── -->
    <parameter name="REPORT_DATE" class="java.lang.String">
        <defaultValueExpression><![CDATA["—"]]></defaultValueExpression>
    </parameter>

    <!-- ── Fields ── -->
    <field name="batchId"    class="java.lang.String"/>
    <field name="chequeNo"   class="java.lang.String"/>
    <field name="chequeDate" class="java.time.LocalDateTime"/>
    <field name="micrCode"   class="java.lang.String"/>
    <field name="payeeName"  class="java.lang.String"/>
    <field name="amount"     class="java.math.BigDecimal"/>
    <field name="reason"     class="java.lang.String"/>

    <!-- ── Variables ── -->

    <!-- Running subtotal per batch group -->
    <variable name="BATCH_SUBTOTAL" class="java.math.BigDecimal"
              resetType="Group" resetGroup="batchGroup"
              calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>

    <!-- Grand total across all batches -->
    <variable name="GRAND_TOTAL" class="java.math.BigDecimal"
              resetType="Report"
              calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>

    <!-- ── Group by batchId ── -->
    <group name="batchGroup" isStartNewPage="false" isReprintHeaderOnEachPage="true">
        <groupExpression><![CDATA[$F{batchId}]]></groupExpression>

        <!-- Group Header: batch label + column headings -->
        <groupHeader>
            <band height="48">

                <!-- Thin top rule -->
                <line>
                    <reportElement x="0" y="0" width="555" height="1" forecolor="#CCCCCC"/>
                </line>

                <!-- "Batch: Batch_001" label — full width, no badge -->
                <textField>
                    <reportElement x="0" y="6" width="555" height="18"/>
                    <textElement>
                        <font size="10" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Batch:  " + $F{batchId}]]></textFieldExpression>
                </textField>

                <!-- Column headings row -->
                <rectangle>
                    <reportElement x="0" y="26" width="555" height="18" backcolor="#FEF3F2" forecolor="#FEF3F2"/>
                </rectangle>

                <!-- Col 1: Cheque No  x=2,  w=56 -->
                <staticText>
                    <reportElement x="2"   y="27" width="56"  height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Cheque No]]></text>
                </staticText>
                <!-- Col 2: Date  x=60, w=64 -->
                <staticText>
                    <reportElement x="60"  y="27" width="64" height="16"/>
                    <textElement><font size="7" isBold="true"/></textElement>
                    <text><![CDATA[Date]]></text>
                </staticText>
                <!-- Col 3: MICR  x=126, w=68 -->
                <staticText>
                    <reportElement x="126" y="27" width="68" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[MICR]]></text>
                </staticText>
                <!-- Col 4: Payee Name  x=196, w=130 -->
                <staticText>
                    <reportElement x="196" y="27" width="130" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Payee Name]]></text>
                </staticText>
                <!-- Col 5: Return Reason  x=328, w=140 -->
                <staticText>
                    <reportElement x="328" y="27" width="140" height="16"/>
                    <textElement><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Return Reason]]></text>
                </staticText>
                <!-- Col 6: Amount  x=470, w=83 — right-aligned -->
                <staticText>
                    <reportElement x="470" y="27" width="83"  height="16"/>
                    <textElement textAlignment="Right"><font size="8" isBold="true"/></textElement>
                    <text><![CDATA[Amount (Rs.)]]></text>
                </staticText>
            </band>
        </groupHeader>

        <!-- Group Footer: subtotal row -->
        <groupFooter>
            <band height="26">
                <line>
                    <reportElement x="0" y="1" width="555" height="1" forecolor="#AAAAAA"/>
                </line>
                <staticText>
                    <reportElement x="328" y="4" width="140" height="16"/>
                    <textElement textAlignment="Right">
                        <font size="9" isBold="true"/>
                    </textElement>
                    <text><![CDATA[Batch Subtotal:]]></text>
                </staticText>
                <textField pattern="#,##0.00">
                    <reportElement x="470" y="4" width="83" height="16"/>
                    <textElement textAlignment="Right">
                        <font size="9" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$V{BATCH_SUBTOTAL}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- ── Title ── -->
    <title>
        <band height="60">

            <!-- Report heading -->
            <staticText>
                <reportElement x="0" y="0" width="400" height="24"/>
                <textElement>
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[RRF REPORT — RETURNED CHEQUES]]></text>
            </staticText>

            <!-- Date on the right -->
            <textField>
                <reportElement x="400" y="0" width="155" height="16"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Date: " + $P{REPORT_DATE}]]></textFieldExpression>
            </textField>

            <!-- Horizontal rule under title -->
            <line>
                <reportElement x="0" y="30" width="555" height="1" forecolor="#DC2626"/>
            </line>
        </band>
    </title>

    <!-- ── Detail rows ── -->
    <detail>
        <band height="18">

            <!-- Col 1: Cheque No -->
            <textField isBlankWhenNull="true">
                <reportElement x="2"   y="1" width="56"  height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{chequeNo}]]></textFieldExpression>
            </textField>

            <!-- Col 2: Date -->
            <textField isBlankWhenNull="true">
                <reportElement x="60"  y="1" width="64" height="16"/>
                <textElement><font size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{chequeDate} != null ? $F{chequeDate}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yyyy")) : "-"]]></textFieldExpression>
            </textField>

            <!-- Col 3: MICR -->
            <textField isBlankWhenNull="true">
                <reportElement x="126" y="1" width="68" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{micrCode}]]></textFieldExpression>
            </textField>

            <!-- Col 4: Payee Name -->
            <textField isBlankWhenNull="true">
                <reportElement x="196" y="1" width="130" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{payeeName}]]></textFieldExpression>
            </textField>

            <!-- Col 5: Return Reason -->
            <textField isBlankWhenNull="true">
                <reportElement x="328" y="1" width="140" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{reason}]]></textFieldExpression>
            </textField>

            <!-- Col 6: Amount (right-aligned) -->
            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="470" y="1" width="83"  height="16"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ── Summary: grand total ── -->
    <summary>
        <band height="36">
            <line>
                <reportElement x="0" y="2" width="555" height="1" forecolor="#DC2626"/>
            </line>
            <staticText>
                <reportElement x="0" y="8" width="470" height="18"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[GRAND TOTAL:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="470" y="8" width="83" height="18"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{GRAND_TOTAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>