<?xml version="1.0" encoding="UTF-8"?>
<?page title="Resubmitted Cheques | CTS" contentType="text/html;charset=UTF-8"?>
<zk xmlns="http://www.zkoss.org/2005/zul"
    xmlns:n="native"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.zkoss.org/2005/zul http://www.zkoss.org/2005/zul/zul.xsd">

    <style src="/css/inward/Inwardmakerstyles.css"/>
    <style src="/css/inward/checkerStyles.css"/>
    <style src="/css/inward/cts-breadcrumb-filter-theme.css"/>

    <div apply="com.cts.inward.composer.TV1_ResubmittedQueueComposer"
         sclass="rcb-page-wrap">

        <!-- Scrollable content -->
        <div sclass="rcb-scroll-area">

            <!-- Breadcrumb -->
            <div sclass="cts-breadcrumb">
                <n:span class="cts-breadcrumb-item">Home</n:span>
                <n:span class="cts-breadcrumb-sep">›</n:span>
                <n:span class="cts-breadcrumb-active">Resubmitted Cheques</n:span>
            </div>

            <!-- Page header -->
            <div sclass="page-hdr">
                <div>
                    <div sclass="page-title">
                        <n:span class="chk-title-dot">🔄</n:span>
                        Resubmitted Cheques
                        <label id="chk-count-badge"
                               sclass="chk-count-badge"
                               value="—"/>
                    </div>
                    <div sclass="page-sub">
                        Cheques resubmitted by Maker after correction — review and clear (≤ ₹1,00,000)
                    </div>
                </div>
                <button id="chk-btn-refresh"
                        sclass="chk-btn-refresh"
                        autodisable="false">
                    ↺ Refresh
                </button>
            </div>

            <!-- Success banner -->
            <div id="chk-success-banner" visible="false"
                 sclass="chk-success-banner">
                <n:span class="rcb-success-icon">✅</n:span>
                <n:div id="chk-success-text"
                       sclass="chk-success-text"></n:div>
                <button id="chk-success-dismiss"
                        sclass="chk-success-dismiss"
                        autodisable="false">✕</button>
            </div>

            <!-- Alert banner -->
            <div id="chk-alert-banner" sclass="chk-alert-banner" visible="false">
                <n:span class="rcb-alert-icon">🔄</n:span>
                <n:span>
                    <n:strong>Pending Review</n:strong>
                    — The following cheques were resubmitted by Maker.
                    Click <n:strong>Review</n:strong> to open the review workspace.
                </n:span>
            </div>

            <!-- Filter bar — Dashboard style -->
            <div sclass="search-bar">

                <div sclass="srch-field-grow">
                    <label value="SEARCH CHEQUE / BATCH" sclass="srch-label"/>
                    <textbox id="chk-search"
                             placeholder="Cheque no. or Batch ID..."
                             width="100%"/>
                </div>

                <div sclass="srch-field">
                    <label value="EDITED BY MAKER" sclass="srch-label"/>
                    <listbox id="chk-edited-filter" mold="select" width="160px">
                        <listitem label="All Cheques" value="" selected="true"/>
                        <listitem label="Edited Only" value="YES"/>
                        <listitem label="Not Edited"  value="NO"/>
                    </listbox>
                </div>

                <div sclass="srch-field">
                    <label value="BATCH NUMBER" sclass="srch-label"/>
                    <listbox id="chk-batch-filter" mold="select" width="160px">
                        <listitem label="All Batches" value="" selected="true"/>
                    </listbox>
                </div>

                <button id="chk-btn-search" sclass="btn-search-srch" label="🔍 Search" autodisable="false"/>
                <button id="chk-btn-clear-filter" sclass="btn-clear-srch" label="✕ Clear" autodisable="false"/>

            </div>

            <div sclass="cts-table-wrap cts-merged-table">
                <grid id="chk-grid" sclass="rcb-grid">
                    <columns sizable="false" sclass="cts-grid-header-blue">
                        <column label="#"                       width="45px"  align="center"/>
                        <column label="Cheque No."              width="110px" align="center"/>
                        <column label="Batch ID"                width="110px" align="center"/>
                        <column label="Amount (&#8377;)"        width="105px" align="center"/>
                        <column label="Checker Sendback Reason" width="260px" align="left"/>
                        <column label="Edited"                  width="90px"  align="center"/>
                        <column label="Action"                  width="110px" align="center"/>
                    </columns>
                    <rows id="chk-rows">
                        <row id="chk-empty-row" visible="false">
                            <cell colspan="7">
                                <n:div class="rcb-empty-state">
                                    <n:div class="chk-empty-icon">✅</n:div>
                                    <n:div class="chk-empty-title">
                                        No Resubmitted Cheques
                                    </n:div>
                                    <n:div class="chk-empty-desc">
                                        All resubmitted cheques have been reviewed.
                                        Nothing pending for Verifier 1.
                                    </n:div>
                                </n:div>
                            </cell>
                        </row>
                    </rows>
                </grid>
            </div>

            <paging id="chk-paging" pageSize="5" totalSize="0"
                    sclass="rcb-paging"/>

        </div>

    </div>

</zk>
